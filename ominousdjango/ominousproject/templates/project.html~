{% extends 'base.html' %}

{% block content %}

<link rel="stylesheet" href="/static/custom/css/dropdown.css">
<link rel="stylesheet" href="/static/custom/css/category_counter.css">
<link rel="stylesheet" href="/static/custom/css/main.css">

<div class="tab-content" id="pills-tabContent">
	<!--Blogs-->
	<div class="tab-pane fade show active" id="pills-blog" role="tabpanel" aria-labelledby="blog-tab" tabindex="0">
		<script src="/static/custom/js/blogs.js"></script>
		<div class="container-fluid" id="mainLayout">
			<!--1st row-->
			<div class="row">
				<!--Dropdown-->
				<div class="col-4">
				  <button class="button_category bg-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseWidthExample" >
					Categories
				  </button>
					<div style="min-height: 120px;">
					  <div class="collapse collapse-horizontal" id="collapseWidthExample">
						<div class="card card-body bg-dark" style="width: 250px">
							<div class="d-flex align-items-start">
							  <div class="nav bg-dark dropdown flex-column nav-pills me-3" role="tablist" aria-orientation="vertical">
								<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="true">Security<span class="circle"><span id="security_count">0</span></span></button>
								<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Linux<span class="circle"><span id="linux_count">0</span></span></button>
								<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Windows<span class="circle"><span id="windows_count">0</span></span></button>
								<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Software<span class="circle"><span id="software_count">0</span></span></button>
								<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Networking<span class="circle"</span><span id="networking_count">0</span></button>
							</div>
						</div>
					  </div>
					</div>
				</div>
			  </div>
				<!--Search Bar-->
				<div class="col p-4">
					<input onkeyup="search_blog(this);" placeholder="Search blog..." id="bar" class="bg-dark p-3" type="text"/>
				</div>
			</div>
			<!--2nd row-->
			<div class="row">
				<!--Table-->
				<div style="position: absolute;right:0;top:15rem" class="col-8 p-4">
					<table class="table table-dark table-bordered overflow-scroll">
						<tbody id="tbody_blog">
						</tbody>
					</table>
				</div>
			</div>
			<!--3rd row-->
			<div class="row">
				<!--pageLayout-->
				<div id="pageLayout_blog" class="col overflow-scroll">
				</div>
			</div>
		</div>

	</div>

	<!--Notes-->
	<div class="tab-pane fade" id="pills-notes" role="tabpanel" aria-labelledby="notes-tab" tabindex="0">

		<script src="/static/custom/js/notes.js"></script>
		<div class="container-fluid" id="mainLayout">
			<!--1st row-->
			<div class="row">
				<!--Dropdown-->
				<div class="col-3">
				  <button onclick="absolute_notes();" class="button_category bg-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseWidthExample" >
						Categories
				  </button>
					<div>
						<div class="collapse collapse-horizontal" id="collapseWidthExample">
							<div class="card card-body bg-dark" style="width: 250px">
								<div class="d-flex align-items-start">
									<div class="nav bg-dark dropdown flex-column nav-pills me-3" id="v-pills-tab" role="tablist" aria-orientation="vertical">
										<button onclick="request_notes(this);" class="nav-link category_item" data-bs-toggle="pill" data-bs-target="#v-pills-home" type="button" role="tab" aria-controls="v-pills-home" aria-selected="true">Pwn<span class="circle"><span id="pwn_count">0</span></span></button>
										<button onclick="request_notes(this);" class="nav-link category_item" id="v-pills-profile-tab" data-bs-toggle="pill" data-bs-target="#v-pills-profile" type="button" role="tab" aria-controls="v-pills-profile" aria-selected="false">Web<span class="circle"><span id="web_count">0</span></span></button>
										<button onclick="request_notes(this);" class="nav-link category_item" id="v-pills-messages-tab" data-bs-toggle="pill" data-bs-target="#v-pills-messages" type="button" role="tab" aria-controls="v-pills-messages" aria-selected="false">Forensic<span class="circle"><span id="forensic_count">0</span></span></button>
										<button onclick="request_notes(this);" class="nav-link category_item" id="v-pills-settings-tab" data-bs-toggle="pill" data-bs-target="#v-pills-settings" type="button" role="tab" aria-controls="v-pills-settings" aria-selected="false">Crypto<span class="circle"><span id="crypto_count">0</span></span></button>
										<button onclick="request_notes(this);" class="nav-link category_item" id="v-pills-settings-tab" data-bs-toggle="pill" data-bs-target="#v-pills-settings" type="button" role="tab" aria-controls="v-pills-settings" aria-selected="false">Cloud<span class="circle"><span id="cloud_count">0</span></span></button>
										<button onclick="request_notes(this);" class="nav-link category_item" id="v-pills-settings-tab" data-bs-toggle="pill" data-bs-target="#v-pills-settings" type="button" role="tab" aria-controls="v-pills-settings" aria-selected="false">Misc<span class="circle"</span><span id="misc_count">0</span></button>
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
				<!--Search Bar-->
				<div class="col-5 p-4">
					<input onkeyup="search_note(this);" placeholder="Search note..." id="bar" class="bg-dark p-3" type="text"/>
				</div>
				<!--Platform dropdown -->
				<div class="col-1">
					<button onclick="relative_notes();" class="button_platform bg-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseWidthExamples" >
						Platform
					</button>
					<div>
					  <div class="collapse collapse-horizontal" id="collapseWidthExamples">
						<div class="card card-body bg-dark" style="width: 250px">
						  <div class="d-flex align-items-start">
							<div class="nav bg-dark dropdown flex-column nav-pills me-3" id="v-pills-tab" role="tablist" aria-orientation="vertical">
								<button onclick="request_platform(this);" class="nav-link platform_item" data-bs-toggle="pill" data-bs-target="#v-pills-home" type="button" role="tab" aria-controls="v-pills-home" aria-selected="true">Hackthebox</button>
								<button onclick="request_platform(this);" class="nav-link platform_item" id="v-pills-profile-tab" data-bs-toggle="pill" data-bs-target="#v-pills-profile" type="button" role="tab" aria-controls="v-pills-profile" aria-selected="false">Tryhackme</button>
								<button onclick="request_platform(this);" class="nav-link platform_item" id="v-pills-messages-tab" data-bs-toggle="pill" data-bs-target="#v-pills-messages" type="button" role="tab" aria-controls="v-pills-messages" aria-selected="false">Overthewire</button>
							</div>
						</div>
					  </div>
					</div>
				  </div>
				</div>
				<!--Table-->
				<div style="position:absolute;right:0;top:15rem" id="table" class="col-8 p-4">
					<table class="table table-dark table-bordered overflow-scroll">
						<tbody id="tbody_notes">
						</tbody>
					</table>
				</div>
		</div>
		<!--2nd row-->
		<div class="row">
			<!--pageLayout-->
			<div id="pageLayout_notes" class="col overflow-scroll">
			</div>
		</div>

	  </div>

	</div>
</div>
{% endblock content %}
