{% extends 'base.html' %}

{% block content %}
<link rel="stylesheet" href="/static/custom/css/blog/misc.css">
<link rel="stylesheet" href="/static/custom/css/blog/dropdown.css">
<link rel="stylesheet" href="/static/custom/css/blog/category_counter.css">

<script id="js" src="/static/custom/js/blog/blog.js"></script>
<div class="container-fluid" id="mainLayout">
	<div id="blog-filter-layout">
		<!--1st row-->
		<div class="row">
			<!--Dropdown-->
			<div class="col-4">
			  <button class="button_category bg-dark" type="button" data-bs-toggle="collapse" data-bs-target="#collapseWidthExample" >
				Categories
			  </button>
				<div style="min-height: 120px;">
				  <div class="collapse collapse-horizontal" id="collapseWidthExample">
					<div class="card card-body bg-dark" style="width: 250px">
						<div class="d-flex align-items-start">
						  <div class="nav bg-dark dropdown flex-column nav-pills me-3" role="tablist" aria-orientation="vertical">
							<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="true">Security<span class="circle"><span id="security_count">0</span></span></button>
							<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Linux<span class="circle"><span id="linux_count">0</span></span></button>
							<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Windows<span class="circle"><span id="windows_count">0</span></span></button>
							<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Software<span class="circle"><span id="software_count">0</span></span></button>
							<button onclick="request_blog(this);" class="nav-link category_item" data-bs-toggle="pill" type="button" role="tab" aria-selected="false">Networking<span class="circle"</span><span id="networking_count">0</span></button>
						</div>
					</div>
				  </div>
				</div>
			</div>
		  </div>
			<!--Search Bar-->
			<div class="col p-4">
				<input onkeyup="search_blog(this);" placeholder="Search blog..." id="bar" class="bg-dark p-3" type="text"/>
			</div>
		</div>
		<!--2nd row-->
		<div class="row">
			<!--Table-->
			<div id="blog-table" class="col-8 p-4">
				<table class="table table-dark table-bordered overflow-scroll">
					<tbody id="tbody_blog">
					</tbody>
				</table>
			</div>
		</div>
	</div>
	<!--3rd row-->
	<div class="row">
		<!--pageLayout-->
		<div id="pageLayout_blog" class="col overflow-scroll">
		</div>
	</div>
</div>

{% endblock content %}
